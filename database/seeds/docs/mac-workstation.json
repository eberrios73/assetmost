  "meta": {
    "why": "Every office production laptop/desktop gets this baseline before it reaches its user. An imaged system (Basic Setup) exists for quick deployment; this SOP is the full path and the audit trail.",
    "how": "Work top to bottom. The machine steps generate the bootstrap script at /onboard - run it with sudo on the Mac; it reports each step back to this checklist.",
    "scope": "All office production laptop/desktop systems (macOS) before deployment to the end user.",
    "tools": "Imaged system (Basic Setup) for quick deployment\nPolicyBanner.rtfd.zip on the installers share (Mac folder)\nCanon 6065 vendor driver if the office printer needs it",
    "safety": "System is locked from further changes without IT / Management approval.\nUpdate the asset inventory before deployment - new system, or reassignment to a new user.",
    "os": "macOS",
    "owner": "Enrique Berrios",
    "version": "1.0",
    "status": "Draft"
  }
